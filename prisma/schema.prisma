// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "mysql"
}


// roles table
model Role {
  id Int @default(autoincrement()) @id
  roleName String @db.VarChar(191)
  deletable Boolean @default(true) // true = Yes, False = No
  users User[]
  moduleRole ModuleRole[]
  permissionRole PermissionRole[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// users table
model User {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) 
  email String @unique
  phoneNo String?
  emailVeriafiedAt  DateTime?   @default(now())
  password String
  roleId Int
  role Role @relation(fields: [roleId], references: [id])
  avatar String?
  gender Boolean @default(true) // true = Male, False = Female
  status Boolean @default(true) // true = Active, False = Inactive

  createdBy Int
  creator   User @relation("UserCreatedBy", fields: [createdBy], references: [id])
  createdUsers User[] @relation("UserCreatedBy")

  updatedBy Int?
  updater   User? @relation("UserUpdatedBy", fields: [updatedBy], references: [id])
  updatedUsers User[] @relation("UserUpdatedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departmentCreator Department[] @relation("DepartmentCreatedBy")
  departmentUpdater Department[] @relation("DepartmentUpdatedBy")

  hrmSettingCreator HrmSetting[] @relation("HrmSettingCreatedBy")
  hrmSettingUpdater HrmSetting[] @relation("HrmSettingUpdatedBy")

  employeeCreator Employee[] @relation("EmployeeCreatedBy")
  employeeUpdater Employee[] @relation("EmployeeUpdatedBy")

  attendanceCreator Attendance[] @relation("AttendanceCreatedBy")
  attendanceUpdater Attendance[] @relation("AttendanceUpdatedBy")

  accountCreator Account[] @relation("AccountCreatedBy")
  accountUpdater Account[] @relation("AccountUpdatedBy")

  payrollCreator Payroll[] @relation("PayrollCreatedBy")
  payrollUpdater Payroll[] @relation("PayrollUpdatedBy")

  expenseCategoryCreator ExpenseCategory[] @relation("ExpenseCategoryCreatedBy")
  expenseCategoryUpdater ExpenseCategory[] @relation("ExpenseCategoryUpdatedBy")

  warehouseCreator Warehouse[] @relation("WarehouseCreatedBy")
  warehouseUpdater Warehouse[] @relation("WarehouseUpdatedBy")

  expenseCreator Expense[] @relation("ExpenseCreatedBy")
  expenseUpdater Expense[] @relation("ExpenseUpdatedBy")

  customerGroupCreator CustomerGroup[] @relation("CustomerGroupCreatedBy")
  customerGroupUpdater CustomerGroup[] @relation("CustomerGroupUpdatedBy")

  customerCreator Customer[] @relation("CustomerCreatedBy")
  customerUpdater Customer[] @relation("CustomerUpdatedBy")

  productCategoryCreator ProductCategory[] @relation("ProductCategoryCreatedBy")
  productCategoryUpdater ProductCategory[] @relation("ProductCategoryUpdatedBy")

  brandCreator Brand[] @relation("BrandCreatedBy")
  brandUpdater Brand[] @relation("BrandUpdatedBy")

  taxCreator Tax[] @relation("TaxCreatedBy")
  taxUpdater Tax[] @relation("TaxUpdatedBy")

  unitCreator Unit[] @relation("UnitCreatedBy")
  unitUpdater Unit[] @relation("UnitUpdatedBy")

  productCreator Product[] @relation("ProductCreatedBy")
  productUpdater Product[] @relation("ProductUpdatedBy")

  supplierCreator Supplier[] @relation("SupplierCreatedBy")
  supplierUpdater Supplier[] @relation("SupplierUpdatedBy")

  purchaseCreator Purchase[] @relation("PurchaseCreatedBy")
  purchaseUpdater Purchase[] @relation("PurchaseUpdatedBy")

  saleCreator Sale[] @relation("SaleCreatedBy")
  saleUpdater Sale[] @relation("SaleUpdatedBy")

  paymentCreator Payment[] @relation("PaymentCreatedBy")
  paymentUpdater Payment[] @relation("PaymentUpdatedBy")
}

model Menu{
  id Int @default(autoincrement()) @id
  menuName String
  modules Module[]
  deletable Boolean @default(true) // true = Yes, False = No
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Target {
  SELF  @map("_self")
  BLANK @map("_blank")
}

model Module{
  id Int @default(autoincrement()) @id
  menuId Int
  menu Menu @relation(fields: [menuId], references: [id])
  type Boolean @default(true) // true = Divider, False = Module
  moduleName String?
  dividerTitle String?
  iconClass String?
  url String?
  order Int @default(1)
  parentId Int?
   parent   Module?  @relation("ParentID", fields: [parentId], references: [id])
  children Module[] @relation("ParentID")
  target Target @default(SELF)
  moduleRole ModuleRole[]
  permissions Permission[]
  deletable Boolean @default(true) // true = Yes, False = No
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ModuleRole {
  id Int @default(autoincrement()) @id
  moduleId Int
  module Module @relation(fields: [moduleId], references: [id])
  roleId Int
  role Role @relation(fields: [roleId], references: [id])
  deletable Boolean @default(true) // true = Yes, False = No
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Permission {
  id Int @default(autoincrement()) @id
  moduleId Int?
  module Module? @relation(fields: [moduleId], references: [id])
  name String @db.VarChar(191) 
  slug String @unique
  permissionRole PermissionRole[]
  deletable Boolean @default(true) // true = Yes, False = No
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PermissionRole{
  id Int @default(autoincrement()) @id
  permissionId Int
  permission Permission @relation(fields: [permissionId], references: [id])
  roleId Int
  role Role @relation(fields: [roleId], references: [id])
  deletable Boolean @default(true) // true = Yes, False = No
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HrmSetting {
  id Int @default(autoincrement()) @id
  checkIn String
  checkOut String
  createdBy Int
  creator   User @relation("HrmSettingCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("HrmSettingUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) 
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("DepartmentCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("DepartmentUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments Employee[]
}

model Employee {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) 
  image String?
  phone String @unique
  address String
  city String
  state String
  zip String
  postalCode String?
  country String
  departmentId Int
  department Department @relation(fields: [departmentId], references: [id])
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("EmployeeCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("EmployeeUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attendances Attendance[]
  payrolls Payroll[]
}

model Attendance{
  id Int @default(autoincrement()) @id
  employeeId Int
  employee Employee @relation(fields: [employeeId], references: [id])
  checkIn DateTime
  checkOut DateTime?
  date DateTime
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("AttendanceCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("AttendanceUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id Int @default(autoincrement()) @id
  accountNo String
  name String @db.VarChar(191) 
  initialBalance Decimal @db.Decimal(10, 2)
  note String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("AccountCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("AccountUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payrolls Payroll[]
  expenses Expense[]
  payments Payment[]
}

enum PaymentMethods {
  CASH @map("1")
  CHEQUE @map("2")
  BANK @map("3")
}

model Payroll {
  id Int @default(autoincrement()) @id
  employeeId Int
  employee Employee @relation(fields: [employeeId], references: [id])
  accountId Int
  account Account @relation(fields: [accountId], references: [id])
  amount Decimal @db.Decimal(10, 2)
  paymentMethods PaymentMethods @default(CASH)
  createdBy Int
  creator   User @relation("PayrollCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("PayrollUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Warehouse {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) 
  phone String?
  email String?
  address String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("WarehouseCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("WarehouseUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]
  warehouseProducts WarehouseProduct[]
  purchases Purchase[]
  sale Sale[]
}

model ExpenseCategory {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) 
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("ExpenseCategoryCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("ExpenseCategoryUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses Expense[]
}

model Expense {
  id Int @default(autoincrement()) @id
  expenseCategoryId Int?
  expenseCategory ExpenseCategory? @relation(fields: [expenseCategoryId], references: [id])
  warehouseId Int?
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  accountId Int?
  account Account? @relation(fields: [accountId], references: [id])
  amount Decimal @db.Decimal(10, 2)
  note String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("ExpenseCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("ExpenseUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerGroup{
  id Int @default(autoincrement()) @id
  groupName String
  percentage Float?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("CustomerGroupCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("CustomerGroupUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customers Customer[]
}

model Customer{
  id Int @default(autoincrement()) @id
  customerGroupId Int
  customerGroup CustomerGroup @relation(fields: [customerGroupId], references: [id])
  name String @db.VarChar(191) 
  companyName String?
  taxNumber String?
  email String?
  phone String?
  address String?
  city String?
  state String?
  postalCode String?
  country String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("CustomerCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("CustomerUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales Sale[]
}

model ProductCategory{
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) 
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("ProductCategoryCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("ProductCategoryUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Brand {
  id Int @default(autoincrement()) @id
  title String
  image String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("BrandCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("BrandUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model Tax {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) @unique
  rate Decimal @db.Decimal(10, 2)
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("TaxCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("TaxUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  purchases Purchase[]
  sales Sale[]
  purchaseProductTaxes PurchaseProduct[]
  saleProductTaxes SaleProduct[]
}

model Unit {
  id Int @default(autoincrement()) @id
  unitCode String
  unitName String
  baseUnitId Int?
  baseUnit Unit? @relation("BaseUnitID", fields: [baseUnitId], references: [id])
  baseUnits Unit[] @relation("BaseUnitID")
  operator String @default("*")
  operationValue Decimal @default(1.00) @db.Decimal(10, 2)
  status Boolean @default(true)
  createdBy Int
  creator   User @relation("UnitCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("UnitUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  baseProducts Product[] @relation("ProductBaseUnit")
  purchaseProductsUnit Product[] @relation("ProductPurchaseUnit")
  saleProductsUnit Product[] @relation("ProductSaleUnit")
  purchaseProducts PurchaseProduct[]
  saleProducts SaleProduct[]
}

model Product {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) 
  code String @unique
  barcodeSymbology String
  image String?
  brandId Int?
  brand Brand? @relation(fields: [brandId], references: [id])
  categoryId Int
  category ProductCategory @relation(fields: [categoryId], references: [id])
  unitId Int
  unit Unit @relation("ProductBaseUnit", fields: [unitId], references: [id])
  purchaseUnitId Int
  purchaseUnit Unit @relation("ProductPurchaseUnit", fields: [purchaseUnitId], references: [id])
  saleUnitId Int
  saleUnit Unit @relation("ProductSaleUnit", fields: [saleUnitId], references: [id])
  cost Decimal @db.Decimal(10, 2)
  price Decimal @db.Decimal(10, 2)
  qty Int?
  alertQty Int?
  taxId Int?
  tax Tax? @relation(fields: [taxId], references: [id])
  taxMethod Boolean @default(true) // true = Exclusive, False = Inclusive
  description String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("ProductCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("ProductUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  warehouseProducts WarehouseProduct[]
  pruchaseProducts PurchaseProduct[]
  
  saleProducts SaleProduct[]
}

model WarehouseProduct{
  id Int @default(autoincrement()) @id
  productId Int?
  product Product? @relation(fields: [productId], references: [id])
  warehouseId Int?
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  qty Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Supplier {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) 
  companyName String?
  vatNumber String?
  email String? @unique
  phone String? @unique
  address String?
  city String?
  state String?
  postalCode String?
  country String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("SupplierCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("SupplierUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases Purchase[]
}

enum PurchaseStatus {
  RECEIVED @map("1") // Received
  PARTIAL @map("2") // Partial
  PENDING @map("3") // Pending
  ORDERED @map("4") // Ordered
}

model Purchase {
  id Int @default(autoincrement()) @id
  purchaseNo String @unique
  supplierId Int?
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  warehouseId Int?
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  item Float
  totalQty Float
  totalDiscount Decimal @db.Decimal(10, 2)
  totalTax Decimal @db.Decimal(10, 2)
  totalCost Decimal @db.Decimal(10, 2)
  orderTaxRate Decimal? @db.Decimal(10, 2)
  orderTax Decimal? @db.Decimal(10, 2)
  orderDiscount Decimal? @db.Decimal(10, 2)
  shippingCost Decimal? @db.Decimal(10, 2)
  grandTotal Decimal @db.Decimal(10, 2)
  paidAmount Decimal @db.Decimal(10, 2)
  taxId Int?
  tax Tax? @relation(fields: [taxId], references: [id])
  purchaseStatus PurchaseStatus
  paymentStatus Boolean @default(false) // true = Paid, False = Due
  document String?
  note String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("PurchaseCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("PurchaseUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseProducts PurchaseProduct[]
  payments Payment[]
}

model PurchaseProduct {
  id Int @default(autoincrement()) @id
  purchaseId Int?
  purchase Purchase? @relation(fields: [purchaseId], references: [id])
  productId Int?
  product Product? @relation(fields: [productId], references: [id])
  qty Int
  received Int
  unitId Int
  unit Unit @relation(fields: [unitId], references: [id])
  taxId Int?
  productTax Tax? @relation(fields: [taxId], references: [id])
  netUnitCost Decimal @db.Decimal(10, 2)
  discount Decimal @db.Decimal(10, 2)
  taxRate Decimal @db.Decimal(10, 2)
  tax Decimal @db.Decimal(10, 2)
  total Decimal @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PaymentStatus {
  PAID @map("1") // Paid
  PARTIAL @map("2") // Partial
  DUE @map("3") // Due
}

model Sale {
  id Int @default(autoincrement()) @id
  saleNo String @unique
  customerId Int?
  customer Customer? @relation(fields: [customerId], references: [id])
  warehouseId Int?
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  item Float
  totalQty Float
  totalDiscount Decimal @db.Decimal(10, 2)
  totalTax Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)
  orderTaxRate Decimal? @db.Decimal(10, 2)
  orderTax Decimal? @db.Decimal(10, 2)
  orderDiscount Decimal? @db.Decimal(10, 2)
  shippingCost Decimal? @db.Decimal(10, 2)
  grandTotal Decimal @db.Decimal(10, 2)
  paidAmount Decimal @db.Decimal(10, 2)
  taxId Int?
  tax Tax? @relation(fields: [taxId], references: [id])
  saleStatus Boolean @default(false) // true = Completed, False = Pending
  paymentStatus PaymentStatus
  document String?
  note String?
  status Boolean @default(true) // true = Active, False = Inactive
  createdBy Int
  creator   User @relation("SaleCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("SaleUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleProducts SaleProduct[]
  payments Payment[]
}

model SaleProduct {
  id Int @default(autoincrement()) @id
  saleId Int?
  sale Sale? @relation(fields: [saleId], references: [id])
  productId Int?
  product Product? @relation(fields: [productId], references: [id])
  unitId Int
  unit Unit @relation(fields: [unitId], references: [id])
  qty Int
  taxId Int?
  productTax Tax? @relation(fields: [taxId], references: [id])
  taxRate Decimal @db.Decimal(10, 2)
  tax Decimal @db.Decimal(10, 2)
  netUnitPrice Decimal @db.Decimal(10, 2)
  discount Decimal @db.Decimal(10, 2)
  total Decimal @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id Int @default(autoincrement()) @id
  name String @db.VarChar(191) @unique
  value String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


enum PaymentMethod {
  CASH  @map("1")
  CHEQUE @map("2")
  MOBILE @map("3")
}

model Payment {
  id Int @default(autoincrement()) @id
  accountId Int
  account Account @relation(fields: [accountId], references: [id])
  purchaseId Int?
  purchases Purchase? @relation(fields: [purchaseId], references: [id])
  saleId Int?
  sales Sale? @relation(fields: [saleId], references: [id])
  amount Decimal @db.Decimal(10, 2)
  change Decimal? @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(CASH)
  paymentNo String?
  paymentNote String?
  createdBy Int
  creator   User @relation("PaymentCreatedBy", fields: [createdBy], references: [id])
  updatedBy Int?
  updater   User? @relation("PaymentUpdatedBy", fields: [updatedBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
